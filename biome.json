{
  "$schema": "https://biomejs.dev/schemas/2.5.5/schema.json",
  "files": {
    "includes": ["src/**/*.mjs", "scripts/**/*.mjs", "contracts/**/*.mjs"]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "noUndeclaredVariables": "error",
        "noUnreachable": "error"
      },
      "suspicious": {
        "noDuplicateObjectKeys": "error",
        "noDuplicateParameters": "error"
      }
    }
  }
}
