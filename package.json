{
  "name": "browser67",
  "version": "0.3.0",
  "description": "browser67 real-browser agent runtime for Chrome/Edge automation, browser67-backed JS reverse workflows, evidence capture, native fallback, and long-term agent tooling.",
  "type": "module",
  "keywords": [
    "browser67",
    "mcp",
    "agent-runtime",
    "real-browser",
    "browser-automation",
    "chrome",
    "edge",
    "tmwd",
    "js-reverse",
    "evidence",
    "codex",
    "pi-package"
  ],
  "homepage": "https://github.com/bigKING67/browser67#readme",
  "bugs": {
    "url": "https://github.com/bigKING67/browser67/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bigKING67/browser67.git"
  },
  "bin": {
    "browser67": "./bin/browser67.mjs",
    "tmwd-browser-mcp": "./bin/tmwd-browser-mcp.mjs",
    "tmwd-browser": "./bin/tmwd-browser.mjs"
  },
  "pi": {
    "skills": [
      "skills/browser67",
      "skills/tmwd-browser-mcp",
      "skills/js-reverse"
    ]
  },
  "scripts": {
    "server": "node src/mcp/browser/server.mjs",
    "js-reverse:server": "node src/mcp/js-reverse/server.mjs",
    "setup": "node scripts/setup-extension.mjs",
    "setup:local-extension": "node scripts/setup-extension.mjs --target runtime/chrome-extension/tmwd_cdp_bridge --skip-registry",
    "extension:build": "node scripts/build-extension.mjs",
    "extension:doctor": "node scripts/extension-install-doctor.mjs --json",
    "extension:reload-live": "node scripts/reload-extension-live.mjs",
    "doctor": "node contracts/browser67-live-gate.mjs --doctor-only --tmwd-mode tmwd --disable-event-log",
    "doctor:json": "node contracts/browser67-live-gate.mjs --doctor-only --tmwd-mode tmwd --disable-event-log --json",
    "doctor:agent": "node scripts/agent-integration-doctor.mjs",
    "hub": "node src/tmwd-hub.mjs",
    "hub:start": "node src/tmwd-hub-control.mjs start",
    "hub:status": "node src/tmwd-hub-control.mjs status",
    "hub:stop": "node src/tmwd-hub-control.mjs stop",
    "native:doctor": "node src/native-deps-setup.mjs",
    "native:setup": "node src/native-deps-setup.mjs --install --yes",
    "setup:captcha-provider:jfbym": "node scripts/setup-captcha-provider-jfbym.mjs",
    "extension:sync": "node scripts/sync-genericagent-extension.mjs",
    "extension:check": "node scripts/sync-genericagent-extension.mjs --check",
    "upstream:lock": "node scripts/upstream-lock.mjs --write",
    "upstream:check": "node scripts/upstream-lock.mjs --check",
    "upstream:audit": "node scripts/upstream-audit.mjs",
    "upstream:audit:latest": "node scripts/upstream-audit.mjs --latest-temp",
    "upstream:review-refresh-plan": "node scripts/upstream-review-refresh-plan.mjs",
    "js-reverse:upstream-audit": "node scripts/js-reverse-upstream-audit.mjs",
    "skills:check": "node scripts/check-js-reverse-sync.mjs",
    "skills:active:diff": "node scripts/active-skill-sync.mjs --json",
    "skills:active:check": "node scripts/active-skill-sync.mjs --check",
    "skills:active:sync": "node scripts/active-skill-sync.mjs --write",
    "skills:active:backups": "node scripts/active-skill-sync.mjs --list-backups --json",
    "skills:active:restore": "node scripts/active-skill-sync.mjs --restore",
    "skills:roots:audit": "node scripts/skills-roots-audit.mjs",
    "tasks:templates": "node scripts/task-template.mjs list --json",
    "check:pi-package": "node contracts/pi-package-contract.mjs",
    "lint": "biome lint src scripts contracts",
    "type-check": "tsc -p tsconfig.checkjs.json",
    "check:syntax": "node scripts/syntax-check.mjs",
    "check:dependency-boundaries": "node scripts/dependency-boundary-audit.mjs",
    "check:project-structure": "node scripts/project-structure-audit.mjs",
    "check:change-set-contract": "node contracts/change-set-contract.mjs",
    "check:change-set": "node scripts/check-change-set.mjs --fail-ungrouped",
    "runtime:cleanup": "node scripts/cleanup-runtime-artifacts.mjs",
    "runtime:cleanup:dry-run": "node scripts/cleanup-runtime-artifacts.mjs --dry-run",
    "runtime:migrate": "node scripts/migrate-runtime-store.mjs",
    "migrate:home": "node scripts/migrate-home.mjs",
    "plan:scoped-commits": "node scripts/plan-scoped-commits.mjs",
    "check:readiness": "node scripts/readiness-audit.mjs",
    "gate": "node scripts/run-verification.mjs",
    "check": "node scripts/run-verification.mjs --tier check",
    "check:mcp": "node contracts/browser67-browser-mcp-contract.mjs",
    "check:browser-runtime": "node contracts/browser-runtime-contract.mjs",
    "check:browser-content-core": "node contracts/browser-content-core-contract.mjs",
    "check:run-store": "node contracts/run-store-contract.mjs",
    "check:job-persistence": "node contracts/browser-job-persistence-contract.mjs",
    "check:hub-control": "node contracts/browser67-hub-control-contract.mjs",
    "check:hub-relay": "node contracts/browser67-hub-relay-contract.mjs",
    "check:doctor-schema": "node contracts/browser-doctor-json-schema-contract.mjs",
    "check:js-reverse-mcp": "node contracts/js-reverse-mcp-contract.mjs",
    "check:js-reverse-upstream": "node contracts/js-reverse-upstream-reference-contract.mjs",
    "check:js-reverse-upstream-audit": "node contracts/js-reverse-upstream-audit-contract.mjs",
    "check:js-reverse-absorption-matrix": "node contracts/js-reverse-absorption-matrix-contract.mjs",
    "check:active-skill-sync": "node contracts/active-skill-sync-contract.mjs",
    "check:skills-roots-audit": "node contracts/skills-roots-audit-contract.mjs",
    "check:browser67-naming": "node contracts/browser67-naming-contract.mjs",
    "check:runtime-home": "node contracts/runtime-home-contract.mjs",
    "check:setup-extension": "node contracts/setup-extension-contract.mjs",
    "check:extension-build": "node contracts/extension-build-contract.mjs",
    "check:extension-managed-runtime": "node contracts/extension-managed-runtime-contract.mjs",
    "check:extension-install-doctor": "node contracts/extension-install-doctor-contract.mjs",
    "check:extension-reload-live": "node contracts/extension-reload-live-contract.mjs",
    "check:agent-integration-doctor": "node contracts/agent-integration-doctor-contract.mjs",
    "check:tmwd-runtime-dispose": "node contracts/tmwd-runtime-dispose-contract.mjs",
    "check:tmwd-transport-health": "node contracts/tmwd-transport-health-contract.mjs",
    "check:extension": "node scripts/check-extension-bridge.mjs",
    "check:upstream-audit": "node contracts/upstream-audit-contract.mjs",
    "check:upstream-review": "node contracts/upstream-review-schema-contract.mjs",
    "check:upstream-review-refresh-plan": "node contracts/upstream-review-refresh-plan-contract.mjs",
    "check:performance-smoke": "node scripts/performance-smoke.mjs",
    "check:regression-matrix": "node scripts/regression-matrix.mjs --json",
    "check:verification-manifest": "node scripts/verification-manifest.mjs --check",
    "check:task-templates": "node scripts/task-template.mjs check --json",
    "check:managed-tabs-clean": "node scripts/check-managed-tab-cleanup.mjs",
    "check:runtime-cleanup": "node contracts/runtime-artifact-cleanup-contract.mjs",
    "check:js-reverse-live": "node contracts/js-reverse-mcp-live-gate.mjs --tmwd-mode tmwd --tmwd-transport auto",
    "check:remote-cdp": "node contracts/browser67-remote-cdp-contract.mjs",
    "check:live": "node contracts/browser67-live-gate.mjs --tmwd-mode tmwd --tmwd-transport auto --disable-event-log",
    "check:live:doctor": "node contracts/browser67-live-gate.mjs --doctor-only --tmwd-mode tmwd --tmwd-transport auto --disable-event-log",
    "check:managed-tab-live": "node contracts/browser-managed-tab-live-smoke.mjs --tmwd-mode tmwd --tmwd-transport auto --require-tabs-get",
    "check:tmwd-performance-live": "node contracts/browser-tmwd-performance-live-smoke.mjs --tmwd-mode tmwd --tmwd-transport auto --require-tabs-get",
    "check:screenshot-live": "node contracts/browser-screenshot-live-smoke.mjs --tmwd-mode tmwd --tmwd-transport auto",
    "check:auth-live": "node contracts/browser-auth-live-smoke.mjs --tmwd-mode tmwd --tmwd-transport auto",
    "check:captcha-assist-live": "node contracts/browser-captcha-assist-live-smoke.mjs --tmwd-mode tmwd --tmwd-transport auto",
    "check:captcha-assist-physical-live": "node contracts/browser-captcha-assist-physical-live-gate.mjs --tmwd-mode tmwd --tmwd-transport auto",
    "check:captcha-router": "node contracts/browser-captcha-router-contract.mjs",
    "check:captcha-provider-jfbym": "node contracts/browser-captcha-provider-jfbym-contract.mjs",
    "check:captcha-provider-jfbym-setup": "node contracts/browser-captcha-provider-jfbym-setup-contract.mjs",
    "check:captcha-provider-jfbym-coordinate": "node contracts/browser-captcha-provider-jfbym-coordinate-contract.mjs",
    "check:native-pointer": "node src/native-deps-setup/pointer-readiness.mjs",
    "check:native-live": "node scripts/native-live-proof-gate.mjs",
    "check:ljqctrl": "node contracts/ljqctrl-doctor.mjs",
    "check:optional-live-proofs": "node scripts/optional-live-proof-audit.mjs",
    "check:release-readiness": "node scripts/release-readiness.mjs",
    "coverage:contracts": "c8 --all --extension .mjs --src src --src scripts --reporter=text-summary --reporter=json-summary --reports-dir runtime/coverage npm run check",
    "plan:optional-live-proofs": "node scripts/optional-live-proof-plan.mjs",
    "proof:optional-live-status": "node scripts/optional-live-proof-status.mjs",
    "proof:optional-live-template": "node scripts/optional-live-proof-template.mjs",
    "proof:optional-live-record": "node scripts/optional-live-proof-record.mjs",
    "proof:native-live": "node scripts/native-live-proof-gate.mjs --require-physical",
    "launchd:install": "node scripts/install-launchd.mjs",
    "launchd:uninstall": "node scripts/uninstall-launchd.mjs",
    "release:ready": "node scripts/run-verification.mjs --tier release",
    "release:ready:strict": "node scripts/run-verification.mjs --tier release-strict",
    "verify:ci": "node scripts/run-verification.mjs --tier ci",
    "verify:local": "node scripts/run-verification.mjs --tier local",
    "verify:live": "node scripts/run-verification.mjs --tier live",
    "verify:platform": "node scripts/run-verification.mjs --tier platform",
    "verify:all": "node scripts/run-verification.mjs --tier all",
    "verify:manifest": "node scripts/verification-manifest.mjs --json",
    "verify": "node scripts/verify.mjs",
    "list:files": "find . -path ./node_modules -prune -o -type f -print | sort"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@types/node": "^24.13.3",
    "c8": "^11.0.0",
    "madge": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
