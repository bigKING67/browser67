{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": false,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/runtime/storage/atomic-file.mjs",
    "src/runtime/storage/ndjson.mjs",
    "src/runtime/tab-scheduler.mjs",
    "src/runtime/redaction.mjs"
  ]
}
